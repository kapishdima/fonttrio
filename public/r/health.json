{
  "name": "pairing-health",
  "type": "registry:style",
  "extends": "none",
  "title": "Health — Figtree + Overpass + Inconsolata",
  "description": "Calm and clear. Figtree's friendly geometry in headings paired with Overpass's Highway Gothic roots — designed to be read at speed. Perfect for interfaces where clarity saves lives.",
  "categories": [
    "sans-serif",
    "complementary",
    "healthcare"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/figtree.json",
    "https://www.fonttrio.xyz/r/overpass.json",
    "https://www.fonttrio.xyz/r/inconsolata.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-figtree)",
      "--font-body": "var(--font-overpass)",
      "--font-mono": "var(--font-inconsolata)"
    }
  },
  "css": {
    "@layer base": {
      "h1": {
        "font-family": "var(--font-heading)",
        "font-size": "2.25rem",
        "line-height": "1.2",
        "letter-spacing": "-0.02em",
        "font-weight": "600"
      },
      "h2": {
        "font-family": "var(--font-heading)",
        "font-size": "1.75rem",
        "line-height": "1.25",
        "letter-spacing": "-0.015em",
        "font-weight": "600"
      },
      "h3": {
        "font-family": "var(--font-heading)",
        "font-size": "1.375rem",
        "line-height": "1.3",
        "letter-spacing": "-0.01em",
        "font-weight": "500"
      },
      "h4, h5, h6": {
        "font-family": "var(--font-heading)",
        "letter-spacing": "-0.005em"
      },
      "body, p": {
        "font-family": "var(--font-body)",
        "line-height": "1.65"
      },
      "code, pre": {
        "font-family": "var(--font-mono)"
      }
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "calm",
      "clear"
    ],
    "useCase": [
      "healthcare",
      "wellness",
      "medical"
    ],
    "appearance": [
      "modern",
      "humanist"
    ]
  }
}
