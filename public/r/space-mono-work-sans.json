{
  "name": "pairing-space-mono-work-sans",
  "type": "registry:style",
  "extends": "none",
  "title": "Space Mono Work Sans — Space Mono + Work Sans + Inconsolata",
  "description": "Space Mono’s personality pairs well with neutral Work Sans.",
  "categories": [
    "google fonts"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/space-mono.json",
    "https://www.fonttrio.xyz/r/work-sans.json",
    "https://www.fonttrio.xyz/r/inconsolata.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-space-mono)",
      "--font-body": "var(--font-work-sans)",
      "--font-mono": "var(--font-inconsolata)"
    }
  },
  "css": {
    "@layer base": {
      "h1": {
        "font-family": "var(--font-heading)",
        "font-size": "2.25rem",
        "line-height": "1.15",
        "letter-spacing": "-0.03em",
        "font-weight": "700"
      },
      "h2": {
        "font-family": "var(--font-heading)",
        "font-size": "1.875rem",
        "line-height": "1.2",
        "letter-spacing": "-0.025em",
        "font-weight": "600"
      },
      "h3": {
        "font-family": "var(--font-heading)",
        "font-size": "1.5rem",
        "line-height": "1.25",
        "letter-spacing": "-0.02em",
        "font-weight": "600"
      },
      "h4, h5, h6": {
        "font-family": "var(--font-heading)",
        "letter-spacing": "-0.01em"
      },
      "body, p": {
        "font-family": "var(--font-body)",
        "line-height": "1.6"
      },
      "code, pre": {
        "font-family": "var(--font-mono)"
      }
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "modern",
      "bold"
    ],
    "useCase": [
      "general"
    ]
  }
}
