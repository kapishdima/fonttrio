{
  "name": "pairing-literary",
  "type": "registry:style",
  "extends": "none",
  "title": "Literary — EB Garamond + Crimson Text + Inconsolata",
  "description": "Pure literary elegance. Two old-style serifs in conversation — Garamond's refined Renaissance forms meet Crimson's contemporary interpretation, creating a scholarly harmony.",
  "categories": [
    "serif",
    "harmonious",
    "literary"
  ],
  "registryDependencies": [],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-eb-garamond)",
      "--font-body": "var(--font-crimson-text)",
      "--font-mono": "var(--font-inconsolata)",
      "--font-eb-garamond": "EB Garamond",
      "--font-crimson-text": "Crimson Text",
      "--font-inconsolata": "Inconsolata"
    }
  },
  "css": {
    "@import \"@fontsource-variable/eb-garamond\"": {},
    "@import \"@fontsource/crimson-text\"": {},
    "@import \"@fontsource-variable/inconsolata\"": {},
    "h1": {
      "font-family": "var(--font-heading)",
      "font-size": "2.5rem",
      "line-height": "1.15",
      "letter-spacing": "-0.015em",
      "font-weight": "400"
    },
    "h2": {
      "font-family": "var(--font-heading)",
      "font-size": "2rem",
      "line-height": "1.2",
      "letter-spacing": "-0.01em",
      "font-weight": "400"
    },
    "h3": {
      "font-family": "var(--font-heading)",
      "font-size": "1.5rem",
      "line-height": "1.3",
      "letter-spacing": "0em",
      "font-weight": "400"
    },
    "h4, h5, h6": {
      "font-family": "var(--font-heading)",
      "letter-spacing": "0em"
    },
    "body, p": {
      "font-family": "var(--font-body)",
      "line-height": "1.75"
    },
    "code, pre": {
      "font-family": "var(--font-mono)"
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "scholarly",
      "literary"
    ],
    "useCase": [
      "publishing",
      "literature",
      "academic"
    ]
  },
  "dependencies": [
    "@fontsource-variable/eb-garamond",
    "@fontsource/crimson-text",
    "@fontsource-variable/inconsolata"
  ]
}
