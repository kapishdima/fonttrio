{
  "name": "pairing-agency",
  "type": "registry:style",
  "extends": "none",
  "title": "Agency — Schibsted Grotesk + Karla + Fira Code",
  "description": "Nordic minimalism meets grotesque warmth. Schibsted Grotesk's Scandinavian clarity in headlines paired with Karla's quirky grotesque personality for body text that feels human.",
  "categories": [
    "sans-serif",
    "complementary",
    "nordic"
  ],
  "registryDependencies": [],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-schibsted-grotesk)",
      "--font-body": "var(--font-karla)",
      "--font-mono": "var(--font-fira-code)",
      "--font-schibsted-grotesk": "Schibsted Grotesk",
      "--font-karla": "Karla",
      "--font-fira-code": "Fira Code"
    }
  },
  "css": {
    "@import \"@fontsource-variable/schibsted-grotesk\"": {},
    "@import \"@fontsource-variable/karla\"": {},
    "@import \"@fontsource-variable/fira-code\"": {},
    "h1": {
      "font-family": "var(--font-heading)",
      "font-size": "2.25rem",
      "line-height": "1.15",
      "letter-spacing": "-0.03em",
      "font-weight": "700"
    },
    "h2": {
      "font-family": "var(--font-heading)",
      "font-size": "1.875rem",
      "line-height": "1.2",
      "letter-spacing": "-0.025em",
      "font-weight": "600"
    },
    "h3": {
      "font-family": "var(--font-heading)",
      "font-size": "1.5rem",
      "line-height": "1.25",
      "letter-spacing": "-0.02em",
      "font-weight": "600"
    },
    "h4, h5, h6": {
      "font-family": "var(--font-heading)",
      "letter-spacing": "-0.01em"
    },
    "body, p": {
      "font-family": "var(--font-body)",
      "line-height": "1.6"
    },
    "code, pre": {
      "font-family": "var(--font-mono)"
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "minimal",
      "nordic"
    ],
    "useCase": [
      "agency",
      "design",
      "portfolio"
    ]
  },
  "dependencies": [
    "@fontsource-variable/schibsted-grotesk",
    "@fontsource-variable/karla",
    "@fontsource-variable/fira-code"
  ]
}
