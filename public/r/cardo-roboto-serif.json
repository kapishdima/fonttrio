{
  "name": "pairing-cardo-roboto-serif",
  "type": "registry:style",
  "extends": "none",
  "title": "Cardo Roboto Serif — Cardo + Roboto Serif + Fira Code",
  "description": "Cardo paired with Roboto Serif for a google fonts aesthetic.",
  "categories": [
    "google fonts"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/cardo.json",
    "https://www.fonttrio.xyz/r/roboto-serif.json",
    "https://www.fonttrio.xyz/r/fira-code.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-cardo)",
      "--font-body": "var(--font-roboto-serif)",
      "--font-mono": "var(--font-fira-code)"
    }
  },
  "css": {
    "@layer base": {
      "h1": {
        "font-family": "var(--font-heading)",
        "font-size": "2.5rem",
        "line-height": "1.15",
        "letter-spacing": "-0.015em",
        "font-weight": "400"
      },
      "h2": {
        "font-family": "var(--font-heading)",
        "font-size": "2rem",
        "line-height": "1.2",
        "letter-spacing": "-0.01em",
        "font-weight": "400"
      },
      "h3": {
        "font-family": "var(--font-heading)",
        "font-size": "1.5rem",
        "line-height": "1.3",
        "letter-spacing": "0em",
        "font-weight": "400"
      },
      "h4, h5, h6": {
        "font-family": "var(--font-heading)",
        "letter-spacing": "0em"
      },
      "body, p": {
        "font-family": "var(--font-body)",
        "line-height": "1.75"
      },
      "code, pre": {
        "font-family": "var(--font-mono)"
      }
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "versatile"
    ],
    "useCase": [
      "general"
    ]
  }
}
