{
  "name": "pairing-inknut-antiqua-be-vietnam",
  "type": "registry:style",
  "extends": "none",
  "title": "Inknut Antiqua Be Vietnam — Inknut Antiqua + Be Vietnam Pro + JetBrains Mono",
  "description": "Be Vietnam Pro keeps things readable and UI-friendly.",
  "categories": [
    "serif-sans serif"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/inknut-antiqua.json",
    "https://www.fonttrio.xyz/r/be-vietnam-pro.json",
    "https://www.fonttrio.xyz/r/jetbrains-mono.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-inknut-antiqua)",
      "--font-body": "var(--font-be-vietnam-pro)",
      "--font-mono": "var(--font-jetbrains-mono)"
    }
  },
  "css": {
    "@layer base": {
      "h1": {
        "font-family": "var(--font-heading)",
        "font-size": "2.25rem",
        "line-height": "1.2",
        "letter-spacing": "-0.025em",
        "font-weight": "700"
      },
      "h2": {
        "font-family": "var(--font-heading)",
        "font-size": "1.875rem",
        "line-height": "1.25",
        "letter-spacing": "-0.02em",
        "font-weight": "600"
      },
      "h3": {
        "font-family": "var(--font-heading)",
        "font-size": "1.5rem",
        "line-height": "1.3",
        "letter-spacing": "-0.015em",
        "font-weight": "600"
      },
      "h4, h5, h6": {
        "font-family": "var(--font-heading)",
        "letter-spacing": "-0.01em"
      },
      "body, p": {
        "font-family": "var(--font-body)",
        "line-height": "1.65"
      },
      "code, pre": {
        "font-family": "var(--font-mono)"
      }
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "technical"
    ],
    "useCase": [
      "web app",
      "tech"
    ]
  }
}
