{
  "name": "pairing-commons",
  "type": "registry:style",
  "extends": "none",
  "title": "Commons — Cabin + Mukta + Fira Code",
  "description": "Humanist warmth across scripts. Cabin's slightly condensed forms give headings a distinct character, while Mukta — designed for both Devanagari and Latin — brings inclusive readability to body text.",
  "categories": [
    "sans-serif",
    "complementary",
    "inclusive"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/cabin.json",
    "https://www.fonttrio.xyz/r/mukta.json",
    "https://www.fonttrio.xyz/r/fira-code.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-cabin)",
      "--font-body": "var(--font-mukta)",
      "--font-mono": "var(--font-fira-code)"
    }
  },
  "css": {
    "h1": {
      "font-family": "var(--font-heading)",
      "font-size": "2.25rem",
      "line-height": "1.2",
      "letter-spacing": "-0.02em",
      "font-weight": "600"
    },
    "h2": {
      "font-family": "var(--font-heading)",
      "font-size": "1.75rem",
      "line-height": "1.25",
      "letter-spacing": "-0.015em",
      "font-weight": "600"
    },
    "h3": {
      "font-family": "var(--font-heading)",
      "font-size": "1.375rem",
      "line-height": "1.3",
      "letter-spacing": "-0.01em",
      "font-weight": "500"
    },
    "h4, h5, h6": {
      "font-family": "var(--font-heading)",
      "letter-spacing": "-0.005em"
    },
    "body, p": {
      "font-family": "var(--font-body)",
      "line-height": "1.65"
    },
    "code, pre": {
      "font-family": "var(--font-mono)"
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "approachable",
      "inclusive"
    ],
    "useCase": [
      "community",
      "nonprofit",
      "education"
    ]
  }
}
