{
  "name": "pairing-crimson-pro-crimson-text",
  "type": "registry:style",
  "extends": "none",
  "title": "Crimson Pro Crimson Text — Crimson Pro + Crimson Text + IBM Plex Mono",
  "description": "Crimson Pro paired with Crimson Text for a google fonts aesthetic.",
  "categories": [
    "google fonts"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/crimson-pro.json",
    "https://www.fonttrio.xyz/r/crimson-text.json",
    "https://www.fonttrio.xyz/r/ibm-plex-mono.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-crimson-pro)",
      "--font-body": "var(--font-crimson-text)",
      "--font-mono": "var(--font-ibm-plex-mono)"
    }
  },
  "css": {
    "@layer base": {
      "h1": {
        "font-family": "var(--font-heading)",
        "font-size": "2.5rem",
        "line-height": "1.15",
        "letter-spacing": "-0.015em",
        "font-weight": "400"
      },
      "h2": {
        "font-family": "var(--font-heading)",
        "font-size": "2rem",
        "line-height": "1.2",
        "letter-spacing": "-0.01em",
        "font-weight": "400"
      },
      "h3": {
        "font-family": "var(--font-heading)",
        "font-size": "1.5rem",
        "line-height": "1.3",
        "letter-spacing": "0em",
        "font-weight": "400"
      },
      "h4, h5, h6": {
        "font-family": "var(--font-heading)",
        "letter-spacing": "0em"
      },
      "body, p": {
        "font-family": "var(--font-body)",
        "line-height": "1.75"
      },
      "code, pre": {
        "font-family": "var(--font-mono)"
      }
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "versatile"
    ],
    "useCase": [
      "general"
    ]
  }
}
