{
  "name": "pairing-space-mono-lora",
  "type": "registry:style",
  "extends": "none",
  "title": "Space Mono Lora — Space Mono + Lora + Roboto Mono",
  "description": "Lora brings warmth and structure under bold Space Mono headings.",
  "categories": [
    "serif-monospace"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/space-mono.json",
    "https://www.fonttrio.xyz/r/lora.json",
    "https://www.fonttrio.xyz/r/roboto-mono.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-space-mono)",
      "--font-body": "var(--font-lora)",
      "--font-mono": "var(--font-roboto-mono)"
    }
  },
  "css": {
    "@layer base": {
      "h1": {
        "font-family": "var(--font-heading)",
        "font-size": "2.25rem",
        "line-height": "1.2",
        "letter-spacing": "-0.02em",
        "font-weight": "600"
      },
      "h2": {
        "font-family": "var(--font-heading)",
        "font-size": "1.75rem",
        "line-height": "1.25",
        "letter-spacing": "-0.015em",
        "font-weight": "600"
      },
      "h3": {
        "font-family": "var(--font-heading)",
        "font-size": "1.375rem",
        "line-height": "1.3",
        "letter-spacing": "-0.01em",
        "font-weight": "500"
      },
      "h4, h5, h6": {
        "font-family": "var(--font-heading)",
        "letter-spacing": "-0.005em"
      },
      "body, p": {
        "font-family": "var(--font-body)",
        "line-height": "1.65"
      },
      "code, pre": {
        "font-family": "var(--font-mono)"
      }
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "versatile"
    ],
    "useCase": [
      "general"
    ]
  }
}
