{
  "name": "pairing-beacon",
  "type": "registry:style",
  "extends": "none",
  "title": "Beacon — Exo 2 + Titillium Web + Source Code Pro",
  "description": "Space-age geometry. Exo 2's futuristic proportions make headlines feel like mission control, while Titillium Web's Italian polytechnic origins keep body text grounded in engineering precision.",
  "categories": [
    "sans-serif",
    "geometric",
    "futuristic"
  ],
  "registryDependencies": [
    "https://fonttrio.dev/r/exo-2.json",
    "https://fonttrio.dev/r/titillium-web.json",
    "https://fonttrio.dev/r/source-code-pro.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-exo-2)",
      "--font-body": "var(--font-titillium-web)",
      "--font-mono": "var(--font-source-code-pro)"
    }
  },
  "css": {
    "h1": {
      "font-family": "var(--font-heading)",
      "font-size": "2.5rem",
      "line-height": "1.1",
      "letter-spacing": "-0.03em",
      "font-weight": "700"
    },
    "h2": {
      "font-family": "var(--font-heading)",
      "font-size": "2rem",
      "line-height": "1.15",
      "letter-spacing": "-0.025em",
      "font-weight": "600"
    },
    "h3": {
      "font-family": "var(--font-heading)",
      "font-size": "1.5rem",
      "line-height": "1.25",
      "letter-spacing": "-0.015em",
      "font-weight": "600"
    },
    "h4, h5, h6": {
      "font-family": "var(--font-heading)",
      "letter-spacing": "-0.01em"
    },
    "body, p": {
      "font-family": "var(--font-body)",
      "line-height": "1.6"
    },
    "code, pre": {
      "font-family": "var(--font-mono)"
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "futuristic",
      "technical"
    ],
    "useCase": [
      "tech",
      "space",
      "gaming"
    ]
  }
}
