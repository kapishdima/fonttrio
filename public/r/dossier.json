{
  "name": "pairing-dossier",
  "type": "registry:style",
  "extends": "none",
  "title": "Dossier — Barlow Condensed + Barlow + IBM Plex Mono",
  "description": "California grotesk in two widths. Barlow Condensed packs maximum information into headlines, while regular Barlow breathes in body text. A superfamily designed for screen-first interfaces.",
  "categories": [
    "sans-serif",
    "superfamily",
    "condensed"
  ],
  "registryDependencies": [],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-barlow-condensed)",
      "--font-body": "var(--font-barlow)",
      "--font-mono": "var(--font-ibm-plex-mono)",
      "--font-barlow-condensed": "Barlow Condensed",
      "--font-barlow": "Barlow",
      "--font-ibm-plex-mono": "IBM Plex Mono"
    }
  },
  "css": {
    "@import \"@fontsource/barlow-condensed\"": {},
    "@import \"@fontsource/barlow\"": {},
    "@import \"@fontsource/ibm-plex-mono\"": {},
    "h1": {
      "font-family": "var(--font-heading)",
      "font-size": "2.25rem",
      "line-height": "1.15",
      "letter-spacing": "-0.03em",
      "font-weight": "700"
    },
    "h2": {
      "font-family": "var(--font-heading)",
      "font-size": "1.875rem",
      "line-height": "1.2",
      "letter-spacing": "-0.025em",
      "font-weight": "600"
    },
    "h3": {
      "font-family": "var(--font-heading)",
      "font-size": "1.5rem",
      "line-height": "1.25",
      "letter-spacing": "-0.02em",
      "font-weight": "600"
    },
    "h4, h5, h6": {
      "font-family": "var(--font-heading)",
      "letter-spacing": "-0.01em"
    },
    "body, p": {
      "font-family": "var(--font-body)",
      "line-height": "1.6"
    },
    "code, pre": {
      "font-family": "var(--font-mono)"
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "efficient",
      "modern"
    ],
    "useCase": [
      "dashboard",
      "data",
      "news"
    ]
  },
  "dependencies": [
    "@fontsource/barlow-condensed",
    "@fontsource/barlow",
    "@fontsource/ibm-plex-mono"
  ]
}
