{
  "name": "pairing-scholar",
  "type": "registry:style",
  "extends": "none",
  "title": "Scholar — EB Garamond + Inter + Source Code Pro",
  "description": "Academic precision meets digital clarity. EB Garamond's renaissance roots lend authority to headings, while Inter ensures perfect screen readability for long-form content.",
  "categories": [
    "serif",
    "contrast",
    "academic"
  ],
  "registryDependencies": [],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-eb-garamond)",
      "--font-body": "var(--font-inter)",
      "--font-mono": "var(--font-source-code-pro)",
      "--font-eb-garamond": "EB Garamond",
      "--font-inter": "Inter",
      "--font-source-code-pro": "Source Code Pro"
    }
  },
  "css": {
    "@import \"@fontsource-variable/eb-garamond\"": {},
    "@import \"@fontsource-variable/inter\"": {},
    "@import \"@fontsource-variable/source-code-pro\"": {},
    "h1": {
      "font-family": "var(--font-heading)",
      "font-size": "2.5rem",
      "line-height": "1.15",
      "letter-spacing": "-0.015em",
      "font-weight": "400"
    },
    "h2": {
      "font-family": "var(--font-heading)",
      "font-size": "2rem",
      "line-height": "1.2",
      "letter-spacing": "-0.01em",
      "font-weight": "400"
    },
    "h3": {
      "font-family": "var(--font-heading)",
      "font-size": "1.5rem",
      "line-height": "1.3",
      "letter-spacing": "0em",
      "font-weight": "400"
    },
    "h4, h5, h6": {
      "font-family": "var(--font-heading)",
      "letter-spacing": "0em"
    },
    "body, p": {
      "font-family": "var(--font-body)",
      "line-height": "1.75"
    },
    "code, pre": {
      "font-family": "var(--font-mono)"
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "academic",
      "refined"
    ],
    "useCase": [
      "documentation",
      "research",
      "education"
    ]
  },
  "dependencies": [
    "@fontsource-variable/eb-garamond",
    "@fontsource-variable/inter",
    "@fontsource-variable/source-code-pro"
  ]
}
