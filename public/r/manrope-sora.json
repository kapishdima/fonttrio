{
  "name": "pairing-manrope-sora",
  "type": "registry:style",
  "extends": "none",
  "title": "Manrope Sora — Manrope + Sora + Inconsolata",
  "description": "Sora softens Manrope’s geometry with playful curves.",
  "categories": [
    "sans serif-sans serif"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/manrope.json",
    "https://www.fonttrio.xyz/r/sora.json",
    "https://www.fonttrio.xyz/r/inconsolata.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-manrope)",
      "--font-body": "var(--font-sora)",
      "--font-mono": "var(--font-inconsolata)"
    }
  },
  "css": {
    "@layer base": {
      "h1": {
        "font-family": "var(--font-heading)",
        "font-size": "2.25rem",
        "line-height": "1.15",
        "letter-spacing": "-0.03em",
        "font-weight": "700"
      },
      "h2": {
        "font-family": "var(--font-heading)",
        "font-size": "1.875rem",
        "line-height": "1.2",
        "letter-spacing": "-0.025em",
        "font-weight": "600"
      },
      "h3": {
        "font-family": "var(--font-heading)",
        "font-size": "1.5rem",
        "line-height": "1.25",
        "letter-spacing": "-0.02em",
        "font-weight": "600"
      },
      "h4, h5, h6": {
        "font-family": "var(--font-heading)",
        "letter-spacing": "-0.01em"
      },
      "body, p": {
        "font-family": "var(--font-body)",
        "line-height": "1.6"
      },
      "code, pre": {
        "font-family": "var(--font-mono)"
      }
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "bold"
    ],
    "useCase": [
      "branding"
    ]
  }
}
