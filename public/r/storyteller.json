{
  "name": "pairing-storyteller",
  "type": "registry:style",
  "extends": "none",
  "title": "Storyteller — Lora + Nunito Sans + Inconsolata",
  "description": "Warm and inviting. Lora's brushed curves bring narrative warmth to headlines, while Nunito Sans's rounded terminals keep body text approachable and easy to scan.",
  "categories": [
    "serif",
    "contrast",
    "warm"
  ],
  "registryDependencies": [],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-lora)",
      "--font-body": "var(--font-nunito-sans)",
      "--font-mono": "var(--font-inconsolata)",
      "--font-lora": "Lora",
      "--font-nunito-sans": "Nunito Sans",
      "--font-inconsolata": "Inconsolata"
    }
  },
  "css": {
    "@import \"@fontsource-variable/lora\"": {},
    "@import \"@fontsource-variable/nunito-sans\"": {},
    "@import \"@fontsource-variable/inconsolata\"": {},
    "h1": {
      "font-family": "var(--font-heading)",
      "font-size": "2.25rem",
      "line-height": "1.2",
      "letter-spacing": "-0.025em",
      "font-weight": "700"
    },
    "h2": {
      "font-family": "var(--font-heading)",
      "font-size": "1.875rem",
      "line-height": "1.25",
      "letter-spacing": "-0.02em",
      "font-weight": "600"
    },
    "h3": {
      "font-family": "var(--font-heading)",
      "font-size": "1.5rem",
      "line-height": "1.3",
      "letter-spacing": "-0.015em",
      "font-weight": "600"
    },
    "h4, h5, h6": {
      "font-family": "var(--font-heading)",
      "letter-spacing": "-0.01em"
    },
    "body, p": {
      "font-family": "var(--font-body)",
      "line-height": "1.65"
    },
    "code, pre": {
      "font-family": "var(--font-mono)"
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "warm",
      "narrative"
    ],
    "useCase": [
      "blog",
      "storytelling",
      "content"
    ]
  },
  "dependencies": [
    "@fontsource-variable/lora",
    "@fontsource-variable/nunito-sans",
    "@fontsource-variable/inconsolata"
  ]
}
