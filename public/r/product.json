{
  "name": "pairing-product",
  "type": "registry:style",
  "extends": "none",
  "title": "Product — Plus Jakarta Sans + Inter + JetBrains Mono",
  "description": "Product-focused clarity. Jakarta's slightly warmer geometry gives headings personality without the noise, while Inter handles the fine print with surgical precision.",
  "categories": [
    "sans-serif",
    "complementary",
    "product"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/plus-jakarta-sans.json",
    "https://www.fonttrio.xyz/r/inter.json",
    "https://www.fonttrio.xyz/r/jetbrains-mono.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-plus-jakarta-sans)",
      "--font-body": "var(--font-inter)",
      "--font-mono": "var(--font-jetbrains-mono)"
    }
  },
  "css": {
    "@layer base": {
      "h1": {
        "font-family": "var(--font-heading)",
        "font-size": "2.25rem",
        "line-height": "1.15",
        "letter-spacing": "-0.03em",
        "font-weight": "700"
      },
      "h2": {
        "font-family": "var(--font-heading)",
        "font-size": "1.875rem",
        "line-height": "1.2",
        "letter-spacing": "-0.025em",
        "font-weight": "600"
      },
      "h3": {
        "font-family": "var(--font-heading)",
        "font-size": "1.5rem",
        "line-height": "1.25",
        "letter-spacing": "-0.02em",
        "font-weight": "600"
      },
      "h4, h5, h6": {
        "font-family": "var(--font-heading)",
        "letter-spacing": "-0.01em"
      },
      "body, p": {
        "font-family": "var(--font-body)",
        "line-height": "1.6"
      },
      "code, pre": {
        "font-family": "var(--font-mono)"
      }
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "friendly",
      "professional"
    ],
    "useCase": [
      "SaaS",
      "product",
      "web app"
    ],
    "appearance": [
      "modern",
      "humanist"
    ]
  }
}
