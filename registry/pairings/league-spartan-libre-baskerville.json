{
  "name": "league-spartan-libre-baskerville",
  "type": "registry:style",
  "extends": "none",
  "title": "League Spartan + Libre Baskerville + Fira Code",
  "description": "Geometric bold sans heading with refined Baskerville body. Modern strength meets classical elegance.",
  "categories": [
    "sans-serif",
    "serif",
    "contrast"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/league-spartan.json",
    "https://www.fonttrio.xyz/r/libre-baskerville.json",
    "https://www.fonttrio.xyz/r/fira-code.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-league-spartan)",
      "--font-body": "var(--font-libre-baskerville)",
      "--font-mono": "var(--font-fira-code)"
    }
  },
  "css": {
    "@layer base": {
      "h1": {
        "font-family": "var(--font-heading)",
        "font-size": "2.25rem",
        "line-height": "1.2",
        "letter-spacing": "-0.02em",
        "font-weight": "600"
      },
      "h2": {
        "font-family": "var(--font-heading)",
        "font-size": "1.75rem",
        "line-height": "1.25",
        "letter-spacing": "-0.015em",
        "font-weight": "600"
      },
      "h3": {
        "font-family": "var(--font-heading)",
        "font-size": "1.375rem",
        "line-height": "1.3",
        "letter-spacing": "-0.01em",
        "font-weight": "500"
      },
      "h4, h5, h6": {
        "font-family": "var(--font-heading)",
        "letter-spacing": "-0.005em"
      },
      "body, p": {
        "font-family": "var(--font-body)",
        "line-height": "1.65"
      },
      "code, pre": {
        "font-family": "var(--font-mono)"
      }
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "strong",
      "elegant",
      "professional"
    ],
    "useCase": [
      "corporate",
      "editorial",
      "portfolio"
    ],
    "appearance": [
      "modern",
      "refined"
    ]
  }
}
