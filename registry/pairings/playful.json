{
  "name": "playful",
  "type": "registry:style",
  "extends": "none",
  "title": "Playful — Quicksand + Cabin + Inconsolata",
  "description": "Rounded and inviting. Quicksand's perfectly circular counters give headings a toy-like friendliness, while Cabin's humanist proportions keep body text grounded and professional.",
  "categories": [
    "sans-serif",
    "complementary",
    "friendly"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/quicksand.json",
    "https://www.fonttrio.xyz/r/cabin.json",
    "https://www.fonttrio.xyz/r/inconsolata.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-quicksand)",
      "--font-body": "var(--font-cabin)",
      "--font-mono": "var(--font-inconsolata)"
    }
  },
  "css": {
    "@layer base": {
      "h1": {
        "font-family": "var(--font-heading)",
        "font-size": "2.25rem",
        "line-height": "1.2",
        "letter-spacing": "-0.02em",
        "font-weight": "600"
      },
      "h2": {
        "font-family": "var(--font-heading)",
        "font-size": "1.75rem",
        "line-height": "1.25",
        "letter-spacing": "-0.015em",
        "font-weight": "600"
      },
      "h3": {
        "font-family": "var(--font-heading)",
        "font-size": "1.375rem",
        "line-height": "1.3",
        "letter-spacing": "-0.01em",
        "font-weight": "500"
      },
      "h4, h5, h6": {
        "font-family": "var(--font-heading)",
        "letter-spacing": "-0.005em"
      },
      "body, p": {
        "font-family": "var(--font-body)",
        "line-height": "1.65"
      },
      "code, pre": {
        "font-family": "var(--font-mono)"
      }
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "playful",
      "approachable"
    ],
    "useCase": [
      "kids",
      "education",
      "consumer app"
    ],
    "appearance": [
      "geometric",
      "humanist"
    ]
  }
}
