{
  "name": "libre-franklin-martel",
  "type": "registry:style",
  "extends": "none",
  "title": "Libre Franklin Martel — Libre Franklin + Martel + IBM Plex Mono",
  "description": "Martel’s traditional structure supports Libre Franklin with gravitas.",
  "categories": [
    "sans serif-serif"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/libre-franklin.json",
    "https://www.fonttrio.xyz/r/martel.json",
    "https://www.fonttrio.xyz/r/ibm-plex-mono.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-libre-franklin)",
      "--font-body": "var(--font-martel)",
      "--font-mono": "var(--font-ibm-plex-mono)"
    }
  },
  "css": {
    "@layer base": {
      "h1": {
        "font-family": "var(--font-heading)",
        "font-size": "2.25rem",
        "line-height": "1.2",
        "letter-spacing": "-0.02em",
        "font-weight": "600"
      },
      "h2": {
        "font-family": "var(--font-heading)",
        "font-size": "1.75rem",
        "line-height": "1.25",
        "letter-spacing": "-0.015em",
        "font-weight": "600"
      },
      "h3": {
        "font-family": "var(--font-heading)",
        "font-size": "1.375rem",
        "line-height": "1.3",
        "letter-spacing": "-0.01em",
        "font-weight": "500"
      },
      "h4, h5, h6": {
        "font-family": "var(--font-heading)",
        "letter-spacing": "-0.005em"
      },
      "body, p": {
        "font-family": "var(--font-body)",
        "line-height": "1.65"
      },
      "code, pre": {
        "font-family": "var(--font-mono)"
      }
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "editorial"
    ],
    "useCase": [
      "editorial"
    ]
  }
}
