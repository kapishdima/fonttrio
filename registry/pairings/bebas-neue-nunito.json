{
  "name": "pairing-bebas-neue-nunito",
  "type": "registry:style",
  "extends": "none",
  "title": "Bebas Neue Nunito — Bebas Neue + Nunito + Roboto Mono",
  "description": "Bebas Neue provides strong visual impact, while Nunito balances it with clear readability.",
  "categories": [
    "mixed"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/bebas-neue.json",
    "https://www.fonttrio.xyz/r/nunito.json",
    "https://www.fonttrio.xyz/r/roboto-mono.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-bebas-neue)",
      "--font-body": "var(--font-nunito)",
      "--font-mono": "var(--font-roboto-mono)"
    }
  },
  "css": {
    "@layer base": {
      "h1": {
        "font-family": "var(--font-heading)",
        "font-size": "2.25rem",
        "line-height": "1.15",
        "letter-spacing": "-0.03em",
        "font-weight": "700"
      },
      "h2": {
        "font-family": "var(--font-heading)",
        "font-size": "1.875rem",
        "line-height": "1.2",
        "letter-spacing": "-0.025em",
        "font-weight": "600"
      },
      "h3": {
        "font-family": "var(--font-heading)",
        "font-size": "1.5rem",
        "line-height": "1.25",
        "letter-spacing": "-0.02em",
        "font-weight": "600"
      },
      "h4, h5, h6": {
        "font-family": "var(--font-heading)",
        "letter-spacing": "-0.01em"
      },
      "body, p": {
        "font-family": "var(--font-body)",
        "line-height": "1.6"
      },
      "code, pre": {
        "font-family": "var(--font-mono)"
      }
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "bold"
    ],
    "useCase": [
      "general"
    ]
  }
}
