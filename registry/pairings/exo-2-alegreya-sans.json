{
  "name": "exo-2-alegreya-sans",
  "type": "registry:style",
  "extends": "none",
  "title": "Exo 2 + Alegreya Sans + Fira Code",
  "description": "Geometric futuristic heading with humanist sans body. Tech-forward yet approachable.",
  "categories": [
    "sans-serif",
    "geometric",
    "modern"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/exo-2.json",
    "https://www.fonttrio.xyz/r/alegreya-sans.json",
    "https://www.fonttrio.xyz/r/fira-code.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-exo-2)",
      "--font-body": "var(--font-alegreya-sans)",
      "--font-mono": "var(--font-fira-code)"
    }
  },
  "css": {
    "@layer base": {
      "h1": {
        "font-family": "var(--font-heading)",
        "font-size": "2.25rem",
        "line-height": "1.15",
        "letter-spacing": "-0.03em",
        "font-weight": "700"
      },
      "h2": {
        "font-family": "var(--font-heading)",
        "font-size": "1.875rem",
        "line-height": "1.2",
        "letter-spacing": "-0.025em",
        "font-weight": "600"
      },
      "h3": {
        "font-family": "var(--font-heading)",
        "font-size": "1.5rem",
        "line-height": "1.25",
        "letter-spacing": "-0.02em",
        "font-weight": "600"
      },
      "h4, h5, h6": {
        "font-family": "var(--font-heading)",
        "letter-spacing": "-0.01em"
      },
      "body, p": {
        "font-family": "var(--font-body)",
        "line-height": "1.6"
      },
      "code, pre": {
        "font-family": "var(--font-mono)"
      }
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "modern",
      "tech",
      "friendly"
    ],
    "useCase": [
      "web app",
      "tech",
      "startup"
    ],
    "appearance": [
      "modern",
      "geometric"
    ]
  }
}
