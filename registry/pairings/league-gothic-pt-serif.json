{
  "name": "league-gothic-pt-serif",
  "type": "registry:style",
  "extends": "none",
  "title": "League Gothic + PT Serif + Fira Code",
  "description": "Tall condensed gothic heading with elegant serif body. Bold editorial presence with classical readability.",
  "categories": [
    "display",
    "serif",
    "editorial"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/league-gothic.json",
    "https://www.fonttrio.xyz/r/pt-serif.json",
    "https://www.fonttrio.xyz/r/fira-code.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-league-gothic)",
      "--font-body": "var(--font-pt-serif)",
      "--font-mono": "var(--font-fira-code)"
    }
  },
  "css": {
    "@layer base": {
      "h1": {
        "font-family": "var(--font-heading)",
        "font-size": "2.75rem",
        "line-height": "1.05",
        "letter-spacing": "-0.035em",
        "font-weight": "800"
      },
      "h2": {
        "font-family": "var(--font-heading)",
        "font-size": "2.25rem",
        "line-height": "1.1",
        "letter-spacing": "-0.025em",
        "font-weight": "700"
      },
      "h3": {
        "font-family": "var(--font-heading)",
        "font-size": "1.75rem",
        "line-height": "1.2",
        "letter-spacing": "-0.02em",
        "font-weight": "700"
      },
      "h4, h5, h6": {
        "font-family": "var(--font-heading)",
        "letter-spacing": "-0.01em"
      },
      "body, p": {
        "font-family": "var(--font-body)",
        "line-height": "1.6"
      },
      "code, pre": {
        "font-family": "var(--font-mono)"
      }
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "bold",
      "editorial",
      "dramatic"
    ],
    "useCase": [
      "magazine",
      "editorial",
      "news"
    ],
    "appearance": [
      "editorial",
      "condensed"
    ]
  }
}
