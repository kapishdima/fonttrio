{
  "name": "pairing-teko-ubuntu",
  "type": "registry:style",
  "extends": "none",
  "title": "Teko Ubuntu — Teko + Ubuntu + JetBrains Mono",
  "description": "Teko paired with Ubuntu for a mixed aesthetic.",
  "categories": [
    "mixed"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/teko.json",
    "https://www.fonttrio.xyz/r/ubuntu.json",
    "https://www.fonttrio.xyz/r/jetbrains-mono.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-teko)",
      "--font-body": "var(--font-ubuntu)",
      "--font-mono": "var(--font-jetbrains-mono)"
    }
  },
  "css": {
    "@layer base": {
      "h1": {
        "font-family": "var(--font-heading)",
        "font-size": "2.25rem",
        "line-height": "1.15",
        "letter-spacing": "-0.03em",
        "font-weight": "700"
      },
      "h2": {
        "font-family": "var(--font-heading)",
        "font-size": "1.875rem",
        "line-height": "1.2",
        "letter-spacing": "-0.025em",
        "font-weight": "600"
      },
      "h3": {
        "font-family": "var(--font-heading)",
        "font-size": "1.5rem",
        "line-height": "1.25",
        "letter-spacing": "-0.02em",
        "font-weight": "600"
      },
      "h4, h5, h6": {
        "font-family": "var(--font-heading)",
        "letter-spacing": "-0.01em"
      },
      "body, p": {
        "font-family": "var(--font-body)",
        "line-height": "1.6"
      },
      "code, pre": {
        "font-family": "var(--font-mono)"
      }
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "versatile"
    ],
    "useCase": [
      "general"
    ]
  }
}
