{
  "name": "pairing-gazette",
  "type": "registry:style",
  "extends": "none",
  "title": "Gazette — Cormorant Garamond + Raleway + Roboto Mono",
  "description": "Old-world elegance meets contemporary grace. Cormorant Garamond's delicate high-contrast strokes create dramatic headlines, balanced by Raleway's geometric sophistication.",
  "categories": [
    "serif",
    "contrast",
    "elegant"
  ],
  "registryDependencies": [
    "https://fonttrio.dev/r/cormorant-garamond.json",
    "https://fonttrio.dev/r/raleway.json",
    "https://fonttrio.dev/r/roboto-mono.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-cormorant-garamond)",
      "--font-body": "var(--font-raleway)",
      "--font-mono": "var(--font-roboto-mono)"
    }
  },
  "css": {
    "h1": {
      "font-family": "var(--font-heading)",
      "font-size": "2.5rem",
      "line-height": "1.15",
      "letter-spacing": "-0.015em",
      "font-weight": "400"
    },
    "h2": {
      "font-family": "var(--font-heading)",
      "font-size": "2rem",
      "line-height": "1.2",
      "letter-spacing": "-0.01em",
      "font-weight": "400"
    },
    "h3": {
      "font-family": "var(--font-heading)",
      "font-size": "1.5rem",
      "line-height": "1.3",
      "letter-spacing": "0em",
      "font-weight": "400"
    },
    "h4, h5, h6": {
      "font-family": "var(--font-heading)",
      "letter-spacing": "0em"
    },
    "body, p": {
      "font-family": "var(--font-body)",
      "line-height": "1.75"
    },
    "code, pre": {
      "font-family": "var(--font-mono)"
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "elegant",
      "dramatic"
    ],
    "useCase": [
      "magazine",
      "luxury",
      "fashion"
    ]
  }
}
