{
  "name": "fira-sans-pt-serif",
  "type": "registry:style",
  "extends": "none",
  "title": "Fira Sans + PT Serif + Fira Code",
  "description": "Humanist sans heading with classical transitional serif body. Professional and well-balanced.",
  "categories": [
    "sans-serif",
    "serif",
    "professional"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/fira-sans.json",
    "https://www.fonttrio.xyz/r/pt-serif.json",
    "https://www.fonttrio.xyz/r/fira-code.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-fira-sans)",
      "--font-body": "var(--font-pt-serif)",
      "--font-mono": "var(--font-fira-code)"
    }
  },
  "css": {
    "@layer base": {
      "h1": {
        "font-family": "var(--font-heading)",
        "font-size": "2.25rem",
        "line-height": "1.2",
        "letter-spacing": "-0.02em",
        "font-weight": "600"
      },
      "h2": {
        "font-family": "var(--font-heading)",
        "font-size": "1.75rem",
        "line-height": "1.25",
        "letter-spacing": "-0.015em",
        "font-weight": "600"
      },
      "h3": {
        "font-family": "var(--font-heading)",
        "font-size": "1.375rem",
        "line-height": "1.3",
        "letter-spacing": "-0.01em",
        "font-weight": "500"
      },
      "h4, h5, h6": {
        "font-family": "var(--font-heading)",
        "letter-spacing": "-0.005em"
      },
      "body, p": {
        "font-family": "var(--font-body)",
        "line-height": "1.65"
      },
      "code, pre": {
        "font-family": "var(--font-mono)"
      }
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "professional",
      "balanced",
      "readable"
    ],
    "useCase": [
      "documentation",
      "corporate",
      "blog"
    ],
    "appearance": [
      "classic",
      "humanist"
    ]
  }
}
