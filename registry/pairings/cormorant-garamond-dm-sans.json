{
  "name": "cormorant-garamond-dm-sans",
  "type": "registry:style",
  "extends": "none",
  "title": "Cormorant Garamond Dm Sans — Cormorant Garamond + DM Sans + Source Code Pro",
  "description": "Cormorant Garamond brings a traditional feel to the modern base of DM Sans.",
  "categories": [
    "serif-sans serif"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/cormorant-garamond.json",
    "https://www.fonttrio.xyz/r/dm-sans.json",
    "https://www.fonttrio.xyz/r/source-code-pro.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-cormorant-garamond)",
      "--font-body": "var(--font-dm-sans)",
      "--font-mono": "var(--font-source-code-pro)"
    }
  },
  "css": {
    "@layer base": {
      "h1": {
        "font-family": "var(--font-heading)",
        "font-size": "2.25rem",
        "line-height": "1.2",
        "letter-spacing": "-0.025em",
        "font-weight": "700"
      },
      "h2": {
        "font-family": "var(--font-heading)",
        "font-size": "1.875rem",
        "line-height": "1.25",
        "letter-spacing": "-0.02em",
        "font-weight": "600"
      },
      "h3": {
        "font-family": "var(--font-heading)",
        "font-size": "1.5rem",
        "line-height": "1.3",
        "letter-spacing": "-0.015em",
        "font-weight": "600"
      },
      "h4, h5, h6": {
        "font-family": "var(--font-heading)",
        "letter-spacing": "-0.01em"
      },
      "body, p": {
        "font-family": "var(--font-body)",
        "line-height": "1.65"
      },
      "code, pre": {
        "font-family": "var(--font-mono)"
      }
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "editorial"
    ],
    "useCase": [
      "editorial"
    ]
  }
}
