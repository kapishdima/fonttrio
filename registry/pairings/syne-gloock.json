{
  "name": "syne-gloock",
  "type": "registry:style",
  "extends": "none",
  "title": "Syne Gloock — Syne + Gloock + Source Code Pro",
  "description": "Gloock introduces a literary and artistic feel to Syne’s bold headers.",
  "categories": [
    "sans serif-serif"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/syne.json",
    "https://www.fonttrio.xyz/r/gloock.json",
    "https://www.fonttrio.xyz/r/source-code-pro.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-syne)",
      "--font-body": "var(--font-gloock)",
      "--font-mono": "var(--font-source-code-pro)"
    }
  },
  "css": {
    "@layer base": {
      "h1": {
        "font-family": "var(--font-heading)",
        "font-size": "2.25rem",
        "line-height": "1.2",
        "letter-spacing": "-0.02em",
        "font-weight": "600"
      },
      "h2": {
        "font-family": "var(--font-heading)",
        "font-size": "1.75rem",
        "line-height": "1.25",
        "letter-spacing": "-0.015em",
        "font-weight": "600"
      },
      "h3": {
        "font-family": "var(--font-heading)",
        "font-size": "1.375rem",
        "line-height": "1.3",
        "letter-spacing": "-0.01em",
        "font-weight": "500"
      },
      "h4, h5, h6": {
        "font-family": "var(--font-heading)",
        "letter-spacing": "-0.005em"
      },
      "body, p": {
        "font-family": "var(--font-body)",
        "line-height": "1.65"
      },
      "code, pre": {
        "font-family": "var(--font-mono)"
      }
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "editorial",
      "modern"
    ],
    "useCase": [
      "editorial"
    ]
  }
}
