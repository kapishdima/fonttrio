{
  "name": "pairing-creative",
  "type": "registry:style",
  "extends": "none",
  "title": "Creative — Space Grotesk + DM Sans + Fira Code",
  "description": "Playful geometric pairing. Bold headings with friendly body text for startups and portfolios.",
  "categories": ["sans-serif", "creative", "geometric"],
  "registryDependencies": [
    "https://fonttrio.dev/r/space-grotesk.json",
    "https://fonttrio.dev/r/dm-sans.json",
    "https://fonttrio.dev/r/fira-code.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-space-grotesk)",
      "--font-body": "var(--font-dm-sans)",
      "--font-mono": "var(--font-fira-code)"
    }
  },
  "css": {
    "h1": { "font-family": "var(--font-heading)", "font-size": "2.5rem", "line-height": "1.15", "letter-spacing": "-0.03em", "font-weight": "700" },
    "h2": { "font-family": "var(--font-heading)", "font-size": "2rem", "line-height": "1.2", "letter-spacing": "-0.02em", "font-weight": "600" },
    "h3": { "font-family": "var(--font-heading)", "font-size": "1.5rem", "line-height": "1.3", "letter-spacing": "-0.015em", "font-weight": "600" },
    "h4, h5, h6": { "font-family": "var(--font-heading)", "letter-spacing": "-0.01em" },
    "body, p": { "font-family": "var(--font-body)", "line-height": "1.6" },
    "code, pre": { "font-family": "var(--font-mono)" }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": ["playful", "startup", "geometric"],
    "useCase": ["landing page", "startup", "portfolio"]
  }
}
