{
  "name": "pairing-technical",
  "type": "registry:style",
  "extends": "none",
  "title": "Technical — IBM Plex Sans + IBM Plex Sans + IBM Plex Mono",
  "description": "Professional IBM Plex family pairing. Designed for documentation and enterprise applications.",
  "categories": ["sans-serif", "technical", "professional"],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/ibm-plex-sans.json",
    "https://www.fonttrio.xyz/r/ibm-plex-mono.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-ibm-plex-sans)",
      "--font-body": "var(--font-ibm-plex-sans)",
      "--font-mono": "var(--font-ibm-plex-mono)"
    }
  },
  "css": {
    "h1": { "font-family": "var(--font-heading)", "font-size": "2.5rem", "line-height": "1.15", "letter-spacing": "-0.02em", "font-weight": "600" },
    "h2": { "font-family": "var(--font-heading)", "font-size": "2rem", "line-height": "1.2", "letter-spacing": "-0.015em", "font-weight": "600" },
    "h3": { "font-family": "var(--font-heading)", "font-size": "1.5rem", "line-height": "1.3", "letter-spacing": "-0.01em", "font-weight": "500" },
    "h4, h5, h6": { "font-family": "var(--font-heading)", "letter-spacing": "-0.01em" },
    "body, p": { "font-family": "var(--font-body)", "line-height": "1.65" },
    "code, pre": { "font-family": "var(--font-mono)" }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": ["professional", "corporate", "IBM-style"],
    "useCase": ["documentation", "enterprise", "developer tools"]
  }
}
