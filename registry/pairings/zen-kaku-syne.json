{
  "name": "pairing-zen-kaku-syne",
  "type": "registry:style",
  "extends": "none",
  "title": "Zen Kaku Syne — Zen Kaku Gothic New + Syne + IBM Plex Mono",
  "description": "Zen Kaku Gothic New supports Syne with neutral, legible body text.",
  "categories": [
    "sans serif-sans serif"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/zen-kaku-gothic-new.json",
    "https://www.fonttrio.xyz/r/syne.json",
    "https://www.fonttrio.xyz/r/ibm-plex-mono.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-zen-kaku-gothic-new)",
      "--font-body": "var(--font-syne)",
      "--font-mono": "var(--font-ibm-plex-mono)"
    }
  },
  "css": {
    "@layer base": {
      "h1": {
        "font-family": "var(--font-heading)",
        "font-size": "2.25rem",
        "line-height": "1.15",
        "letter-spacing": "-0.03em",
        "font-weight": "700"
      },
      "h2": {
        "font-family": "var(--font-heading)",
        "font-size": "1.875rem",
        "line-height": "1.2",
        "letter-spacing": "-0.025em",
        "font-weight": "600"
      },
      "h3": {
        "font-family": "var(--font-heading)",
        "font-size": "1.5rem",
        "line-height": "1.25",
        "letter-spacing": "-0.02em",
        "font-weight": "600"
      },
      "h4, h5, h6": {
        "font-family": "var(--font-heading)",
        "letter-spacing": "-0.01em"
      },
      "body, p": {
        "font-family": "var(--font-body)",
        "line-height": "1.6"
      },
      "code, pre": {
        "font-family": "var(--font-mono)"
      }
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "neutral"
    ],
    "useCase": [
      "branding"
    ]
  }
}
