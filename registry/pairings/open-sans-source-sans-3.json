{
  "name": "open-sans-source-sans-3",
  "type": "registry:style",
  "extends": "none",
  "title": "Open Sans + Source Sans 3 + Fira Code",
  "description": "Two highly legible humanist sans-serifs. Neutral, professional dual-sans pairing for content-heavy sites.",
  "categories": [
    "sans-serif",
    "clean",
    "neutral"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/open-sans.json",
    "https://www.fonttrio.xyz/r/source-sans-3.json",
    "https://www.fonttrio.xyz/r/fira-code.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-open-sans)",
      "--font-body": "var(--font-source-sans-3)",
      "--font-mono": "var(--font-fira-code)"
    }
  },
  "css": {
    "@layer base": {
      "h1": {
        "font-family": "var(--font-heading)",
        "font-size": "2.25rem",
        "line-height": "1.15",
        "letter-spacing": "-0.03em",
        "font-weight": "700"
      },
      "h2": {
        "font-family": "var(--font-heading)",
        "font-size": "1.875rem",
        "line-height": "1.2",
        "letter-spacing": "-0.025em",
        "font-weight": "600"
      },
      "h3": {
        "font-family": "var(--font-heading)",
        "font-size": "1.5rem",
        "line-height": "1.25",
        "letter-spacing": "-0.02em",
        "font-weight": "600"
      },
      "h4, h5, h6": {
        "font-family": "var(--font-heading)",
        "letter-spacing": "-0.01em"
      },
      "body, p": {
        "font-family": "var(--font-body)",
        "line-height": "1.6"
      },
      "code, pre": {
        "font-family": "var(--font-mono)"
      }
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "neutral",
      "professional",
      "clean"
    ],
    "useCase": [
      "documentation",
      "corporate",
      "web app"
    ],
    "appearance": [
      "clean",
      "neutral"
    ]
  }
}
