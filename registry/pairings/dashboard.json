{
  "name": "pairing-dashboard",
  "type": "registry:style",
  "extends": "none",
  "title": "Dashboard — Manrope + DM Sans + Fira Code",
  "description": "Data-driven clarity. Manrope's optical corrections make dense dashboards legible, while DM Sans handles labels and descriptions with compact efficiency.",
  "categories": [
    "sans-serif",
    "complementary",
    "data"
  ],
  "registryDependencies": [
    "https://fonttrio.dev/r/manrope.json",
    "https://fonttrio.dev/r/dm-sans.json",
    "https://fonttrio.dev/r/fira-code.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-manrope)",
      "--font-body": "var(--font-dm-sans)",
      "--font-mono": "var(--font-fira-code)"
    }
  },
  "css": {
    "h1": {
      "font-family": "var(--font-heading)",
      "font-size": "2.25rem",
      "line-height": "1.15",
      "letter-spacing": "-0.03em",
      "font-weight": "700"
    },
    "h2": {
      "font-family": "var(--font-heading)",
      "font-size": "1.875rem",
      "line-height": "1.2",
      "letter-spacing": "-0.025em",
      "font-weight": "600"
    },
    "h3": {
      "font-family": "var(--font-heading)",
      "font-size": "1.5rem",
      "line-height": "1.25",
      "letter-spacing": "-0.02em",
      "font-weight": "600"
    },
    "h4, h5, h6": {
      "font-family": "var(--font-heading)",
      "letter-spacing": "-0.01em"
    },
    "body, p": {
      "font-family": "var(--font-body)",
      "line-height": "1.6"
    },
    "code, pre": {
      "font-family": "var(--font-mono)"
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "analytical",
      "clear"
    ],
    "useCase": [
      "dashboard",
      "analytics",
      "admin"
    ]
  }
}
