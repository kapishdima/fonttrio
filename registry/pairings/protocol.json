{
  "name": "pairing-protocol",
  "type": "registry:style",
  "extends": "none",
  "title": "Protocol — Saira + Ubuntu + IBM Plex Mono",
  "description": "Racing DNA meets open-source philosophy. Saira's motorsport-inspired geometry powers through headlines, while Ubuntu's distinctive humanist forms — Canonical's signature typeface — make body text unmistakably modern.",
  "categories": [
    "sans-serif",
    "complementary",
    "technical"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/saira.json",
    "https://www.fonttrio.xyz/r/ubuntu.json",
    "https://www.fonttrio.xyz/r/ibm-plex-mono.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-saira)",
      "--font-body": "var(--font-ubuntu)",
      "--font-mono": "var(--font-ibm-plex-mono)"
    }
  },
  "css": {
    "h1": {
      "font-family": "var(--font-heading)",
      "font-size": "2.5rem",
      "line-height": "1.1",
      "letter-spacing": "-0.03em",
      "font-weight": "700"
    },
    "h2": {
      "font-family": "var(--font-heading)",
      "font-size": "2rem",
      "line-height": "1.15",
      "letter-spacing": "-0.025em",
      "font-weight": "600"
    },
    "h3": {
      "font-family": "var(--font-heading)",
      "font-size": "1.5rem",
      "line-height": "1.25",
      "letter-spacing": "-0.015em",
      "font-weight": "600"
    },
    "h4, h5, h6": {
      "font-family": "var(--font-heading)",
      "letter-spacing": "-0.01em"
    },
    "body, p": {
      "font-family": "var(--font-body)",
      "line-height": "1.6"
    },
    "code, pre": {
      "font-family": "var(--font-mono)"
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "technical",
      "distinctive"
    ],
    "useCase": [
      "developer tools",
      "Linux",
      "open source"
    ]
  }
}
