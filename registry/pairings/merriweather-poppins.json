{
  "name": "merriweather-poppins",
  "type": "registry:style",
  "extends": "none",
  "title": "Merriweather Poppins — Merriweather + Poppins + JetBrains Mono",
  "description": "Merriweather adds a soft, approachable feel while Poppins keeps things clean and readable.",
  "categories": [
    "sans serif-sans serif"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/merriweather.json",
    "https://www.fonttrio.xyz/r/poppins.json",
    "https://www.fonttrio.xyz/r/jetbrains-mono.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-merriweather)",
      "--font-body": "var(--font-poppins)",
      "--font-mono": "var(--font-jetbrains-mono)"
    }
  },
  "css": {
    "@layer base": {
      "h1": {
        "font-family": "var(--font-heading)",
        "font-size": "2.25rem",
        "line-height": "1.2",
        "letter-spacing": "-0.025em",
        "font-weight": "700"
      },
      "h2": {
        "font-family": "var(--font-heading)",
        "font-size": "1.875rem",
        "line-height": "1.25",
        "letter-spacing": "-0.02em",
        "font-weight": "600"
      },
      "h3": {
        "font-family": "var(--font-heading)",
        "font-size": "1.5rem",
        "line-height": "1.3",
        "letter-spacing": "-0.015em",
        "font-weight": "600"
      },
      "h4, h5, h6": {
        "font-family": "var(--font-heading)",
        "letter-spacing": "-0.01em"
      },
      "body, p": {
        "font-family": "var(--font-body)",
        "line-height": "1.65"
      },
      "code, pre": {
        "font-family": "var(--font-mono)"
      }
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "approachable"
    ],
    "useCase": [
      "web"
    ]
  }
}
