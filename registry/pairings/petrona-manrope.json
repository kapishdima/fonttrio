{
  "name": "petrona-manrope",
  "type": "registry:style",
  "extends": "none",
  "title": "Petrona Manrope — Petrona + Manrope + Roboto Mono",
  "description": "Manrope supports Petrona’s heritage tone cleanly.",
  "categories": [
    "serif-sans serif"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/petrona.json",
    "https://www.fonttrio.xyz/r/manrope.json",
    "https://www.fonttrio.xyz/r/roboto-mono.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-petrona)",
      "--font-body": "var(--font-manrope)",
      "--font-mono": "var(--font-roboto-mono)"
    }
  },
  "css": {
    "@layer base": {
      "h1": {
        "font-family": "var(--font-heading)",
        "font-size": "2.25rem",
        "line-height": "1.2",
        "letter-spacing": "-0.025em",
        "font-weight": "700"
      },
      "h2": {
        "font-family": "var(--font-heading)",
        "font-size": "1.875rem",
        "line-height": "1.25",
        "letter-spacing": "-0.02em",
        "font-weight": "600"
      },
      "h3": {
        "font-family": "var(--font-heading)",
        "font-size": "1.5rem",
        "line-height": "1.3",
        "letter-spacing": "-0.015em",
        "font-weight": "600"
      },
      "h4, h5, h6": {
        "font-family": "var(--font-heading)",
        "letter-spacing": "-0.01em"
      },
      "body, p": {
        "font-family": "var(--font-body)",
        "line-height": "1.65"
      },
      "code, pre": {
        "font-family": "var(--font-mono)"
      }
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "editorial",
      "modern"
    ],
    "useCase": [
      "editorial"
    ]
  }
}
