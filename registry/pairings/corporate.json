{
  "name": "corporate",
  "type": "registry:style",
  "extends": "none",
  "title": "Corporate — Roboto + Roboto + Roboto Mono",
  "description": "Google's type system. Roboto's dual nature — mechanical skeleton with friendly curves — creates a cohesive experience from headlines to fine print. The de facto standard for Material Design.",
  "categories": [
    "sans-serif",
    "superfamily",
    "corporate"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/roboto.json",
    "https://www.fonttrio.xyz/r/roboto-mono.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-roboto)",
      "--font-body": "var(--font-roboto)",
      "--font-mono": "var(--font-roboto-mono)"
    }
  },
  "css": {
    "@layer base": {
      "h1": {
        "font-family": "var(--font-heading)",
        "font-size": "2.25rem",
        "line-height": "1.15",
        "letter-spacing": "-0.03em",
        "font-weight": "700"
      },
      "h2": {
        "font-family": "var(--font-heading)",
        "font-size": "1.875rem",
        "line-height": "1.2",
        "letter-spacing": "-0.025em",
        "font-weight": "600"
      },
      "h3": {
        "font-family": "var(--font-heading)",
        "font-size": "1.5rem",
        "line-height": "1.25",
        "letter-spacing": "-0.02em",
        "font-weight": "600"
      },
      "h4, h5, h6": {
        "font-family": "var(--font-heading)",
        "letter-spacing": "-0.01em"
      },
      "body, p": {
        "font-family": "var(--font-body)",
        "line-height": "1.6"
      },
      "code, pre": {
        "font-family": "var(--font-mono)"
      }
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "neutral",
      "systematic"
    ],
    "useCase": [
      "enterprise",
      "Android",
      "Material Design"
    ],
    "appearance": [
      "grotesque"
    ]
  }
}
