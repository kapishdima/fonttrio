{
  "name": "roboto-mono-spectral",
  "type": "registry:style",
  "extends": "none",
  "title": "Roboto Mono Spectral — Roboto Mono + Spectral + Source Code Pro",
  "description": "Spectral softens the edge of Roboto Mono for a refined feel.",
  "categories": [
    "serif-monospace"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/roboto-mono.json",
    "https://www.fonttrio.xyz/r/spectral.json",
    "https://www.fonttrio.xyz/r/source-code-pro.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-roboto-mono)",
      "--font-body": "var(--font-spectral)",
      "--font-mono": "var(--font-source-code-pro)"
    }
  },
  "css": {
    "@layer base": {
      "h1": {
        "font-family": "var(--font-heading)",
        "font-size": "2.25rem",
        "line-height": "1.2",
        "letter-spacing": "-0.02em",
        "font-weight": "600"
      },
      "h2": {
        "font-family": "var(--font-heading)",
        "font-size": "1.75rem",
        "line-height": "1.25",
        "letter-spacing": "-0.015em",
        "font-weight": "600"
      },
      "h3": {
        "font-family": "var(--font-heading)",
        "font-size": "1.375rem",
        "line-height": "1.3",
        "letter-spacing": "-0.01em",
        "font-weight": "500"
      },
      "h4, h5, h6": {
        "font-family": "var(--font-heading)",
        "letter-spacing": "-0.005em"
      },
      "body, p": {
        "font-family": "var(--font-body)",
        "line-height": "1.65"
      },
      "code, pre": {
        "font-family": "var(--font-mono)"
      }
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "neutral"
    ],
    "useCase": [
      "general"
    ]
  }
}
