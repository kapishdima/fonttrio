{
	"name": "playfair-display-roboto",
	"type": "registry:style",
	"extends": "none",
	"title": "Playfair Display Inter — Playfair Display + Inter + Inconsolata",
	"description": "Playfair Display delivers high-end flair, complemented by the elegant and refined tone of Inter.",
	"categories": ["display-sans serif"],
	"registryDependencies": [
		"https://www.fonttrio.xyz/r/playfair-display.json",
		"https://www.fonttrio.xyz/r/inter.json",
		"https://www.fonttrio.xyz/r/inconsolata.json"
	],
	"cssVars": {
		"theme": {
			"--font-heading": "var(--font-playfair-display)",
			"--font-body": "var(--font-inter)",
			"--font-mono": "var(--font-inconsolata)"
		}
	},
	"css": {
		"@layer base": {
			"h1": {
				"font-family": "var(--font-heading)",
				"font-size": "2.75rem",
				"line-height": "1.05",
				"letter-spacing": "-0.035em",
				"font-weight": "800"
			},
			"h2": {
				"font-family": "var(--font-heading)",
				"font-size": "2.25rem",
				"line-height": "1.1",
				"letter-spacing": "-0.025em",
				"font-weight": "700"
			},
			"h3": {
				"font-family": "var(--font-heading)",
				"font-size": "1.75rem",
				"line-height": "1.2",
				"letter-spacing": "-0.02em",
				"font-weight": "700"
			},
			"h4, h5, h6": {
				"font-family": "var(--font-heading)",
				"letter-spacing": "-0.01em"
			},
			"body, p": {
				"font-family": "var(--font-body)",
				"line-height": "1.6"
			},
			"code, pre": {
				"font-family": "var(--font-mono)"
			}
		}
	},
	"meta": {
		"preview": "The quick brown fox jumps over the lazy dog",
		"mood": ["editorial", "elegant"],
		"useCase": ["editorial"]
	}
}
