{
  "name": "pairing-fraunces-dm-sans",
  "type": "registry:style",
  "extends": "none",
  "title": "Fraunces Dm Sans — Fraunces + DM Sans + Inconsolata",
  "description": "Fraunces offers expressive character that pairs well with DM Sans’ clarity.",
  "categories": [
    "serif-sans serif"
  ],
  "registryDependencies": [
    "https://www.fonttrio.xyz/r/fraunces.json",
    "https://www.fonttrio.xyz/r/dm-sans.json",
    "https://www.fonttrio.xyz/r/inconsolata.json"
  ],
  "cssVars": {
    "theme": {
      "--font-heading": "var(--font-fraunces)",
      "--font-body": "var(--font-dm-sans)",
      "--font-mono": "var(--font-inconsolata)"
    }
  },
  "css": {
    "@layer base": {
      "h1": {
        "font-family": "var(--font-heading)",
        "font-size": "2.75rem",
        "line-height": "1.05",
        "letter-spacing": "-0.035em",
        "font-weight": "800"
      },
      "h2": {
        "font-family": "var(--font-heading)",
        "font-size": "2.25rem",
        "line-height": "1.1",
        "letter-spacing": "-0.025em",
        "font-weight": "700"
      },
      "h3": {
        "font-family": "var(--font-heading)",
        "font-size": "1.75rem",
        "line-height": "1.2",
        "letter-spacing": "-0.02em",
        "font-weight": "700"
      },
      "h4, h5, h6": {
        "font-family": "var(--font-heading)",
        "letter-spacing": "-0.01em"
      },
      "body, p": {
        "font-family": "var(--font-body)",
        "line-height": "1.6"
      },
      "code, pre": {
        "font-family": "var(--font-mono)"
      }
    }
  },
  "meta": {
    "preview": "The quick brown fox jumps over the lazy dog",
    "mood": [
      "approachable"
    ],
    "useCase": [
      "branding"
    ]
  }
}
