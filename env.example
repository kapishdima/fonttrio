# ─── Supabase ────────────────────────────────────────────────────
# Project Settings → API → Project URL
SUPABASE_URL=https://your-project.supabase.co
# Project Settings → API → anon/public key
SUPABASE_ANON_KEY=your-anon-key
# Project Settings → Database → Connection string (Transaction mode)
SUPABASE_DATABASE_URL=postgresql://postgres.your-project:password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# ─── GitHub OAuth ────────────────────────────────────────────────
# https://github.com/settings/developers → OAuth Apps → New OAuth App
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Google OAuth ────────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Creem ───────────────────────────────────────────────────────
# Dashboard → Settings → Webhooks → Webhook Secret
CREEM_WEBHOOK_SECRET=
# Dashboard → Products → "Fonttrio Pro" → Payment URL
CREEM_PRO_PRODUCT_URL=

# ─── Better Auth ─────────────────────────────────────────────────
# Random secret for signing sessions (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=
# Base URL of the app
BETTER_AUTH_URL=http://localhost:3000
